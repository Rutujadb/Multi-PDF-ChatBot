# =============================================================================
# Multi-PDF ChatBot — environment configuration template
# Copy this file to .env and replace every your_*_here placeholder with real keys.
#   Windows: copy .env.example .env
#   macOS/Linux: cp .env.example .env
# =============================================================================

# --- Active LLM provider ---
# Choose ONE: openrouter | groq | nvidia | gemini
LLM_PROVIDER=openrouter

# --- LLM sampling (optional overrides) ---
LLM_TOP_P=0.85
LLM_TOP_K=40
LLM_REPETITION_PENALTY=1.2
LLM_FREQUENCY_PENALTY=0.3

# --- OpenRouter (if LLM_PROVIDER=openrouter) ---
# Get a key: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemma-2-9b-it:free

# --- Groq + LLaMA (if LLM_PROVIDER=groq) ---
# Get a key: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# --- Nvidia NIM + LLaMA (if LLM_PROVIDER=nvidia) ---
# Get a key: https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_MODEL=meta/llama-4-maverick-17b-128e-instruct

# --- Google Gemini (if LLM_PROVIDER=gemini) ---
# Get a key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL_NAME=gemini-2.0-flash

# --- Vector store ---
VECTOR_STORE=chroma

# --- SQLite chat memory (optional override) ---
# Default: ./data/chat_memory.db (created automatically in Phase 1+)
# CHAT_DB_PATH=./data/chat_memory.db

# --- PDF image extraction (not stored in Chroma) ---
IMAGE_EXTRACTION_ENABLED=true
IMAGE_CAPTION_ENABLED=true
# Use a vision-capable Gemma model (not text-only gemma-2 free tier)
IMAGE_CAPTION_PROVIDER=openrouter
IMAGE_CAPTION_MODEL=google/gemma-3-12b-it
# EXTRACTED_IMAGES_DIR=./data/extracted_images
# IMAGE_DB_PATH=./data/image_manifest.db
# IMAGE_MIN_WIDTH=50
# IMAGE_MIN_HEIGHT=50

# --- Pinecone (only if VECTOR_STORE=pinecone) ---
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=multi-pdf-chatbot

# --- App links ---
STREAMLIT_APP_URL=https://multi-pdf-chatbot-rb.streamlit.app/

# --- Logging (optional — default is INFO) ---
# LOG_LEVEL=INFO

# --- Production CORS (comma-separated React deploy URLs, no trailing slash) ---
# FRONTEND_ALLOWED_ORIGINS=https://your-app.vercel.app
