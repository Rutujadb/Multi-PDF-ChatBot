# --- LLM Configuration ---
LLM_PROVIDER=openrouter                 # Options: openrouter | gemini
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=mistralai/mistral-7b-instruct
LLM_TOP_P=0.85
LLM_TOP_K=40

# --- Gemini (if LLM_PROVIDER=gemini) ---
GOOGLE_API_KEY=your_google_api_key_here

# --- Vector Store Configuration ---
VECTOR_STORE=chroma                    # Options: chroma | pinecone

# --- Pinecone (if VECTOR_STORE=pinecone) ---
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=multi-pdf-chatbot

# --- React UI links ---
STREAMLIT_APP_URL=https://multi-pdf-chatbot-rb.streamlit.app/

# --- Production CORS (comma-separated React deploy URLs, no trailing slash) ---
# FRONTEND_ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-app.pages.dev
